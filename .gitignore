# ----- Misc -----
*.log
*.pdb

# ----- Large reference docs (keep local, don't push) -----
# ST PDFs are freely downloadable; see docs/INDEX.md for the list.
*.pdf

# ----- Local Codex scratch files -----
.codex

# ----- CubeMX reference projects -----
# Throwaway CubeMX-generated trees used to extract init code into the
# hand-maintained repo. Keep the .ioc files (the planning source) and
# ignore everything regenerated from them.
cubemx-reference/**
!cubemx-reference/
!cubemx-reference/*/
!cubemx-reference/**/*.ioc

# ----- Third-party reference code (downloaded locally, don't push) -----
reference/

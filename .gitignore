*.ioc.bak
*.bak
~$*
*.tmp
.mxproject.bak

# ----- STM32CubeIDE (if ever opened accidentally) -----
.cproject
.project
.settings/
.launch
Debug/
Release/

# ----- VS Code (keep shared configs if you add them) -----
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/c_cpp_properties.json
!.vscode/extensions.json

# ----- JetBrains / CLion -----
.idea/

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Python (for tools/) -----
venv/
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----- Misc -----
*.log
*.pdb

# ----- Large reference docs (keep local, don't push) -----
